# ── ClawBoard Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by FastAPI backend)
DATABASE_URL=postgresql+asyncpg://clawboard:clawboard@db:5432/clawboard

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token for creating PRs and pushing code via dispatched agents
# Scopes needed: repo, workflow
GITHUB_TOKEN=ghp_your_token_here

# ── Email Notifications ───────────────────────────────────────────────────────
# Gmail App Password for dispatch completion emails
# Generate at: https://myaccount.google.com/apppasswords
GOOGLE_APP_PASSWORD=your_app_password_here

# Sender Gmail address
EMAIL_SENDER=you@gmail.com

# Comma-separated list of recipient email addresses
EMAIL_RECIPIENTS=you@gmail.com,colleague@example.com

# ── Paths (host filesystem) ───────────────────────────────────────────────────
# Root directory where Claude Code projects live on the host machine
# Mounted into the API container as /projects
HOST_PROJECTS_ROOT=/home/youruser/Projects/ClaudeCodeProject

# Path to OpenClaw cron jobs file (mounted as /openclaw-cron/jobs.json)
# Leave empty if not using OpenClaw cron integration
OPENCLAW_CRON_PATH=/home/youruser/.openclaw/cron

# Path to Claude Code session files (for the Monitor view)
CLAUDE_SESSIONS_PATH=/home/youruser/.claude/projects

# ── Dispatch Settings ─────────────────────────────────────────────────────────
# Minutes before a running dispatch is considered stale/stuck and auto-failed
DISPATCH_STALE_TIMEOUT_MINUTES=30

# ── Optional: Video Editor Skill ─────────────────────────────────────────────
# Path to the video editor SKILL.md (only needed for video-editing task type)
VIDEO_EDITOR_SKILL_PATH=/home/youruser/skills/video-editor/SKILL.md
